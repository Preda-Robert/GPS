Texture2D diffuseTexture1 : register(t0);  
Texture2D normalTexture1 : register(t1);   
Texture2D normalTexture2 : register(t2);   
Texture2D normalTexture3 : register(t3);   
Texture2D grassTexture : register(t4);    
Texture2D grassNormal : register(t5);      

SamplerState SampleType : register(s0);

cbuffer LightBuffer
{
	float4 diffuseColor;
	float3 lightDirection;
	float padding;
};

struct PixelInputType
{
	float4 position : SV_POSITION;
	float2 tex : TEXCOORD0;
	float3 normal : NORMAL;
	float3 tangent : TANGENT;
	float3 binormal : BINORMAL;
	float4 color : COLOR;
	float2 tex2 : TEXCOORD1;
	float4 depthPosition : TEXCOORD2;
	float3 worldPosition : TEXCOORD3; 
};

float4 TerrainPixelShader(PixelInputType input) : SV_TARGET
{
	float slope;
	float height;
	float3 lightDir;
	float4 textureColor1;
	float4 grassColor;
	float3 bumpMap;
	float3 bumpNormal;
	float lightIntensity;
	float4 material1;
	float4 material2;
	float4 materialGrass;
	float blendAmount;
	float4 color;
	float depthValue;
		
	slope = 1.0f - input.normal.y;
	height = input.worldPosition.y; 
	depthValue = input.depthPosition.z / input.depthPosition.w;
	lightDir = -lightDirection;
		
	textureColor1 = diffuseTexture1.Sample(SampleType, input.tex);
		
	grassColor = grassTexture.Sample(SampleType, input.tex);
		
	if (depthValue > 0.998f) {
		bumpMap = normalTexture3.Sample(SampleType, input.tex2).xyz;
	}
	else {
		bumpMap = normalTexture1.Sample(SampleType, input.tex).xyz;
	}
	bumpMap = (bumpMap * 2.0f) - 1.0f;
	bumpNormal = bumpMap.x * input.tangent + bumpMap.y * input.binormal + bumpMap.z * input.normal;
	bumpNormal = normalize(bumpNormal);
	lightIntensity = saturate(dot(bumpNormal, lightDir));
	lightIntensity = max(lightIntensity, 0.2f);  
	material1 = saturate(textureColor1 * lightIntensity);
		
	float3 grassBumpMap = grassNormal.Sample(SampleType, input.tex).xyz;
	grassBumpMap = (grassBumpMap * 2.0f) - 1.0f;
	float3 grassBumpNormal = grassBumpMap.x * input.tangent + grassBumpMap.y * input.binormal + grassBumpMap.z * input.normal;
	grassBumpNormal = normalize(grassBumpNormal);
	float grassLightIntensity = saturate(dot(grassBumpNormal, lightDir));
	grassLightIntensity = max(grassLightIntensity, 0.2f);  
	materialGrass = saturate(grassColor * grassLightIntensity);
		
	bumpMap = normalTexture2.Sample(SampleType, input.tex).xyz;
	bumpMap = (bumpMap * 2.0f) - 1.0f;
	bumpNormal = bumpMap.x * input.tangent + bumpMap.y * input.binormal + bumpMap.z * input.normal;
	bumpNormal = normalize(bumpNormal);
	lightIntensity = saturate(dot(bumpNormal, lightDir));
	lightIntensity = max(lightIntensity, 0.2f);  // Add ambient
	material2 = saturate(float4(1.0f, 1.0f, 1.0f, 1.0f) * lightIntensity);
		
	float lowHeight = 30.0f;    
	float highHeight = 150.0f; 
		
	float normalizedHeight = saturate((height - lowHeight) / (highHeight - lowHeight));
		
	if (slope < 0.2f) {
			
		blendAmount = slope / 0.2f;
				
		float4 flatMaterial = lerp(materialGrass, material2, normalizedHeight);
				
		color = lerp(flatMaterial, material1, blendAmount);
	}
	else if (slope < 0.5f) {
		float rockBlend = (slope - 0.2f) / 0.3f;
		float4 lowMaterial = lerp(materialGrass, material1, rockBlend);
		float4 highMaterial = material1;
		color = lerp(lowMaterial, highMaterial, normalizedHeight);
	}
	else {
		color = material1;
		}
		
	return color;
}